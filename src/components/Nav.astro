---
const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: `${base}#sobre-nosotros`, label: 'Nosotros' },
  { href: `${base}#catalogo`, label: 'Cervezas' },
  { href: `${base}#galeria`, label: 'Galería' },
  { href: `${base}#contacto`, label: 'Contacto' },
];
---

<header id="main-nav" class="fixed top-0 left-0 right-0 z-50">
  <nav class="nav-inner px-6 py-4 w-full">

    <!-- Logo (izquierda) -->
    <a href={base} aria-label="Cuyo Cerveza Artesanal - Inicio" style="margin-left: 1.5rem;">
      <img
        src={`${base}/logo.svg`}
        alt="Cuyo Cerveza Artesanal"
        width="180"
        height="84"
        class="nav-logo"
      />
    </a>

    <!-- Links centrados (solo desktop) -->
    <ul class="nav-links" id="nav-links-desktop">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="nav-link">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Derecha desktop: Instagram -->
    <div class="nav-cta" style="margin-right: 2rem;">
      <a
        href="https://instagram.com/cuyo.cerveza"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-instagram"
        aria-label="Instagram de Cuyo Cerveza Artesanal"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
        </svg>
        Instagram
      </a>
    </div>

    <!-- Hamburger (solo mobile) -->
    <button id="nav-toggle" class="hamburger" aria-label="Abrir menú" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- Menú mobile desplegable -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    {navLinks.map(link => (
      <a href={link.href} class="mobile-nav-link">
        {link.label}
      </a>
    ))}
    <a
      href="https://instagram.com/cuyo.cerveza"
      target="_blank"
      rel="noopener noreferrer"
      class="mobile-nav-instagram"
    >
      Instagram
    </a>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    if (isOpen) {
      mobileMenu?.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      mobileMenu?.setAttribute('aria-hidden', 'true');
    } else {
      mobileMenu?.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
      mobileMenu?.setAttribute('aria-hidden', 'false');
    }
  });

  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  /* ===== FONDO PERMANENTE ===== */
  #main-nav {
    background: color-mix(in srgb, var(--color-surface) 90%, transparent);
    backdrop-filter: blur(var(--nav-blur));
    border-bottom: 1px solid var(--color-surface-high);
  }

  /* ===== NAV INNER ===== */
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  @media (min-width: 768px) {
    .nav-inner {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 1rem;
    }
  }

  /* ===== LOGO ===== */
  .nav-logo {
    height: 5rem;      /* h-20 */
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  /* ===== LINKS DESKTOP ===== */
  .nav-links {
    display: none;
    list-style: none;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-on-surface-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-link:hover {
    color: var(--color-primary);
  }

  /* ===== CTA INSTAGRAM DESKTOP ===== */
  .nav-cta {
    display: none;
  }
  @media (min-width: 768px) {
    .nav-cta {
      display: flex;
      align-items: center;
    }
  }

  .nav-instagram {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .nav-instagram:hover {
    opacity: 0.7;
  }

  /* ===== HAMBURGER MOBILE ===== */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-on-surface);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  /* Ocultar en desktop */
  @media (min-width: 768px) {
    .hamburger {
      display: none;
    }
  }

  /* Animación X al abrir */
  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* ===== MENÚ MOBILE ===== */
  .mobile-menu {
    display: none;
    flex-direction: column;
    background: var(--color-surface-low);
    border-top: 1px solid var(--color-surface-high);
    padding: 1rem 1.5rem 1.5rem;
    gap: 0;
  }

  .mobile-menu.open {
    display: flex;
  }

  @media (min-width: 768px) {
    .mobile-menu {
      display: none !important;
    }
  }

  .mobile-nav-link {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-on-surface-muted);
    text-decoration: none;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-surface-high);
    transition: color 0.2s;
  }
  .mobile-nav-link:hover {
    color: var(--color-primary);
  }

  .mobile-nav-instagram {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    text-decoration: none;
    padding-top: 0.85rem;
  }
</style>
