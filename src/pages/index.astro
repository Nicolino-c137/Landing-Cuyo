---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import SobreNosotros from '../components/SobreNosotros.astro';
import CatalogoSection from '../components/CatalogoSection.astro';
import GaleriaSection from '../components/GaleriaSection.astro';
import ContactoSection from '../components/ContactoSection.astro';
import FooterSection from '../components/FooterSection.astro';
---

<BaseLayout
  title="Cuyo Cerveza Artesanal — Elaborada con alma cuyana"
  description="Cerveza artesanal con identidad cuyana. Elaborada en San Juan con miel sanjuanina, algarrobo de Valle Fértil y pasión por la cultura cervecera."
>
  <main>
    <Nav />
    <HeroSection />
    <SobreNosotros />
    <CatalogoSection />
    <GaleriaSection />
    <ContactoSection />
    <FooterSection />
  </main>

  <script>
    import('../scripts/scroll-animations');
  </script>
</BaseLayout>
