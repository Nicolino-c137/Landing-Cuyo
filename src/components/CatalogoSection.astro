---
import { Image } from 'astro:assets';
import { cervezas } from '../data/cervezas';

import img12 from '../assets/images/imagen12.jpg';
import img13 from '../assets/images/imagen13.jpg';
import img14 from '../assets/images/imagen14.jpg';
import img15 from '../assets/images/imagen15.jpg';
import img16 from '../assets/images/imagen16.jpg';
import img17 from '../assets/images/imagen17.jpg';
import img18 from '../assets/images/imagen18.jpg';
import img19 from '../assets/images/imagen19.jpg';

const imagenes = {
  imagen12: img12,
  imagen13: img13,
  imagen14: img14,
  imagen15: img15,
  imagen16: img16,
  imagen17: img17,
  imagen18: img18,
  imagen19: img19,
} as const;
---

<section id="catalogo" class="py-24 md:py-32 bg-[var(--color-surface)]" data-nav-color="dark">
  <div class="max-w-screen-xl mx-auto px-6 section-container">

    <!-- Header -->
    <div class="fade-in text-center mb-16">
      <p class="text-[var(--color-primary)] text-xs uppercase tracking-[0.3em] mb-4">
        Lo que elaboramos
      </p>
      <h2 class="heading-xl text-white mb-4" style="margin-bottom: 1.5rem;">Nuestras Cervezas</h2>
      <div class="flex justify-center mt-6">
        <div class="gold-divider mx-auto" style="margin-bottom: 3.5rem;"></div>
      </div>
    </div>

    <!-- Grid de cervezas -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {cervezas.map((cerveza) => (
        <article class="cerveza-card fade-in group">

          <!-- Imagen -->
          <div class="cerveza-img-wrap">
            <Image
              src={imagenes[cerveza.imagen as keyof typeof imagenes]}
              alt={cerveza.nombre}
              loading="lazy"
              class="cerveza-img"
              widths={[400, 600]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
            />
            <!-- línea dorada inferior que aparece en hover -->
            <div class="cerveza-line" aria-hidden="true"></div>
          </div>

          <!-- Nombre centrado -->
          <div class="cerveza-info">
            <h3 class="cerveza-nombre">{cerveza.nombre}</h3>
          </div>

        </article>
      ))}
    </div>

<style>
  .cerveza-card {
    display: flex;
    flex-direction: column;
  }

  .cerveza-img-wrap {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .cerveza-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.4);
    transition: filter 0.5s ease, transform 0.5s ease;
  }

  .cerveza-card:hover .cerveza-img {
    filter: grayscale(0);
    transform: scale(1.03);
  }

  .cerveza-line {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background-color: var(--color-primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .cerveza-card:hover .cerveza-line {
    transform: scaleX(1);
  }

  .cerveza-info {
    padding: 1rem 0.25rem 0;
    text-align: center;
  }

  .cerveza-nombre {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
  }
</style>

  </div>
</section>
